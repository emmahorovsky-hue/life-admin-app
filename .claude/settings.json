{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run test)",
      "Bash(npm run test:watch)",
      "Bash(npm run test:coverage)",
      "Bash(npm run test:e2e)",
      "Bash(npm run lint)",
      "Bash(npm run seed)",
      "Bash(npm run prisma:*)",
      "Bash(npm install *)",
      "Bash(npm test)",
      "Bash(npx jest *)",
      "Bash(npx prisma *)",
      "Bash(npx tsc *)",
      "Bash(npx playwright *)",
      "Bash(createdb *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath // \"\"' | { read -r f; [[ \"$f\" =~ /client/.*\\.tsx?$ ]] && (cd client && npx eslint \"$f\"); } || true",
            "statusMessage": "Running ESLint..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git fetch --all --prune 2>&1 || true",
            "statusMessage": "Fetching latest changes..."
          }
        ]
      }
    ]
  }
}
