{
  "framework": "vite",
  "installCommand": "cd .. && npm ci",
  "buildCommand": "cd .. && npm run build --workspace client",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://loyal-magic-production.up.railway.app/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
