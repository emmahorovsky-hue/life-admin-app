{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "API_URL": "http://localhost:3001/api"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "API_URL": "https://REPLACE-WITH-STAGING-API-URL/api"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "API_URL": "https://REPLACE-WITH-PRODUCTION-API-URL/api"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
