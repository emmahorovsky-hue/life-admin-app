# Dependencies
node_modules/

# Environment variables (all variants, in every workspace; .env.example is the
# only variant meant to be committed — CI enforces this, see ci.yml env-file-guard)
.env
.env.*
!.env.example

# Build output
dist/
build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Session artifacts (never commit development session docs)
*_REPORT.md
*_COMPLETE.md
*_STATUS.md
QA_*.md
DEVOPS_*.md
SUBAGENT_*.md
.copilot/
.claude/*
!.claude/settings.json
!.claude/launch.json

# Temporary documentation
docs/local/
*.tmp.md

# Local test/debug artifacts
client/playwright-debug*.mjs
client/test-results/
server/TEST_SETUP.md
