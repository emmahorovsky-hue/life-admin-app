# Database
DATABASE_URL="postgresql://user:password@localhost:5432/lifeadmin?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV="development"

# Frontend URL (for CORS and web redirects)
CLIENT_URL="http://localhost:3000"

# Mobile deep link scheme (for email verification / password reset redirects from mobile)
MOBILE_URL="lifeadmin://"

# Email (for future use)
# RESEND_API_KEY="re_..."
API_URL="http://localhost:3001"

# AI receipt/invoice extraction (optional — feature degrades gracefully without it)
# ANTHROPIC_API_KEY="sk-ant-..."
# AI_MODEL="claude-haiku-4-5"   # default; bump to claude-sonnet-4-6 / claude-opus-4-8 for higher accuracy

# Error monitoring (optional — disabled when not set)
# SENTRY_DSN="https://..."
# SENTRY_RELEASE="1.0.0"   # set in CI/CD to tag errors by deploy (e.g. git SHA)
