# Database
DATABASE_URL="postgresql://user:password@localhost:5432/lifeadmin?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-here"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV="development"

# Frontend URL (for CORS and web redirects)
CLIENT_URL="http://localhost:3000"

# Vercel preview deployments: hostname suffix granted CORS access. Use your
# Vercel TEAM/USER SCOPE slug with a leading dash (e.g. "-beta-flame.vercel.app")
# — the scope slug is the only hostname part Vercel reserves across accounts, so
# anything else (like a project name) could be impersonated by another user.
# A missing leading separator is normalized to "-". Leave unset to disallow
# preview origins.
# VERCEL_PREVIEW_HOST_SUFFIX="-beta-flame.vercel.app"

# Mobile deep link scheme (for email verification / password reset redirects from mobile)
MOBILE_URL="lifeadmin://"

# Email (for future use)
# RESEND_API_KEY="re_..."
# From address on outgoing emails (verification, password reset, reminders).
# Must be a sender/domain verified in Resend.
# EMAIL_FROM="noreply@paypr.live"   # default
API_URL="http://localhost:3001"

# AI receipt/invoice extraction (optional — feature degrades gracefully without it)
# ANTHROPIC_API_KEY="sk-ant-..."
# AI_MODEL="claude-haiku-4-5"   # default; bump to claude-sonnet-4-6 / claude-opus-4-8 for higher accuracy

# Error monitoring (optional — disabled when not set)
# SENTRY_DSN="https://..."
# SENTRY_RELEASE="1.0.0"   # set in CI/CD to tag errors by deploy (e.g. git SHA)

# Background jobs (node-cron). Set ENABLE_CRON=false to skip scheduling entirely
# (e.g. in tests or when running multiple instances that would double-run jobs).
# ENABLE_CRON="true"   # default: anything but "false" enables cron

# Unverified-account cleanup job
# CLEANUP_CRON="0 3 * * *"   # default: daily at 03:00 UTC (standard cron syntax)
# GRACE_PERIOD_DAYS=7        # default: days an account may stay unverified before deletion
# WARNING_LEAD_HOURS=24      # default: hours before the deadline the warning email is sent
#                            # (also the minimum gap between warning and deletion)

# DEV ONLY: disable rate limiting on /api/auth endpoints (e.g. for load testing).
# Ignored (with a warning) when NODE_ENV="production" — auth rate limiting cannot
# be turned off in production.
# DISABLE_AUTH_RATE_LIMIT="false"   # default; set to "true" to disable in dev

# Renewal reminder emails (optional — defaults shown)
# RENEWAL_REMINDER_DAYS=7        # days before renewal to send reminder
# RENEWAL_CRON="0 9 * * *"      # daily 09:00 UTC

# General API rate limit (optional — defaults shown). Coarse per-IP backstop on
# all /api routes; auth endpoints have their own tighter limits on top.
# API_RATE_LIMIT_MAX=300              # requests per window per IP
# API_RATE_LIMIT_WINDOW_MS=900000     # window size (15 minutes)
# DISABLE_RATE_LIMIT="true"           # dev-only escape hatch — ignored when NODE_ENV=production
