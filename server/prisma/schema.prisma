// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // bcrypt hashed
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  subscriptions Subscription[]
  
  @@index([email])
}

model Subscription {
  id           String   @id @default(cuid())
  userId       String
  name         String   // e.g., "Netflix Premium"
  cost         Decimal  @db.Decimal(10, 2) // Supports up to $99,999,999.99
  currency     String   @default("USD") // ISO currency code
  billingCycle String   // "monthly" | "annual" | "weekly" | "quarterly"
  renewalDate  DateTime // Next billing date
  category     String   // "streaming" | "fitness" | "software" | "other"
  notes        String?  // Optional user notes
  isActive     Boolean  @default(true) // Soft delete for cancelled subs
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([renewalDate])
  @@index([category])
}

model NotificationLog {
  id             String   @id @default(cuid())
  userId         String
  subscriptionId String
  type           String   // "renewal_reminder"
  sentAt         DateTime @default(now())
  status         String   // "sent" | "failed"
  
  @@index([userId])
  @@index([subscriptionId])
  @@index([sentAt])
}
