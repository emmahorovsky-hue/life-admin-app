// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password      String   // bcrypt hashed
  name          String?
  surname       String?
  emailVerified Boolean @default(false)   // NEW
  emailVerifiedAt DateTime?                   // NEW
  deletionWarningSentAt DateTime?             // set when grace-period deletion warning email sent
  passwordChangedAt     DateTime?             // set on password reset; tokens issued before this are rejected
  sessionsValidFrom     DateTime?             // set on logout; tokens issued before this are rejected (LIF-174)
  reminderEmailsEnabled Boolean @default(true)  // global toggle for renewal reminder emails
  reminderPushEnabled   Boolean @default(true)  // global toggle for renewal reminder pushes (inert until push ships)
  timezone              String  @default("UTC") // IANA name, auto-detected client-side; drives local-time delivery later
  theme                 String  @default("light") // UI theme: "light" | "dark" | "system"
  defaultCurrency       String  @default("SGD")  // preferred display/new-subscription currency; one of shared `currencies`
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  subscriptions Subscription[]
  emailVerificationTokens EmailVerificationToken[]  // NEW
  passwordResetTokens     PasswordResetToken[]
  emailChangeTokens       EmailChangeToken[]
  deviceTokens            DeviceToken[]
}

model Subscription {
  id           String   @id @default(cuid())
  userId       String
  name         String   // e.g., "Netflix Premium"
  cost         Decimal  @db.Decimal(10, 2) // Supports up to $99,999,999.99
  currency     String   @default("SGD") // ISO currency code
  billingCycle String   // "monthly" | "annual" | "weekly" | "quarterly"
  renewalDate  DateTime // Next billing date
  category     String   // "streaming" | "fitness" | "software" | "other"
  notes        String?  // Optional user notes
  isActive     Boolean  @default(true) // Soft delete (hard "delete" from tracking)
  cancelledAt  DateTime? // Set when the user stops renewal; null = will renew. Sub stays active until renewalDate, then is "ended".
  remindersMuted Boolean @default(false) // per-subscription opt-out from renewal reminders
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([renewalDate])
  @@index([category])
}

model NotificationLog {
  id             String   @id @default(cuid())
  userId         String
  subscriptionId String
  type           String   // "renewal_reminder"
  channel        String   @default("email") // "email" | "push" — each channel dedups independently
  sentAt         DateTime @default(now())
  status         String   // "sent" | "failed"
  renewalDate    DateTime? // renewal occurrence this reminder targeted — dedup key with subscriptionId+type+channel

  @@index([userId])
  @@index([subscriptionId])
  @@index([sentAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique          // sha256(raw), hex
  expiresAt DateTime
  usedAt    DateTime?                  // null = active; set = consumed/invalidated
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailChangeToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique          // sha256(raw), hex
  newEmail  String                     // the address to switch to on confirmation
  expiresAt DateTime
  usedAt    DateTime?                  // null = active; set = consumed/invalidated
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique          // sha256(raw), hex
  email     String                     // snapshot of user.email at issue time
  expiresAt DateTime
  usedAt    DateTime?                  // null = active; set = consumed/invalidated
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model DeviceToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   // "ios" | "android"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
